{
  "version": 1,
  "author": "Fernando",
  "editor": "wokwi",
  "parts": [
    { "type": "board-esp32-devkit-c-v4", "id": "esp", "top": 0, "left": 0, "attrs": {} },
    { "type": "wokwi-relay-module", "id": "rele1", "top": -30, "left": 220, "attrs": {} },
    {
      "type": "wokwi-led",
      "id": "led1",
      "top": 100,
      "left": 440,
      "attrs": { "color": "red", "label": "Ventilador" }
    },
    {
      "type": "wokwi-resistor",
      "id": "r1",
      "top": 100,
      "left": 360,
      "attrs": { "value": "220" }
    }
